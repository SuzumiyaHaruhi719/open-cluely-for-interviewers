# Copy to web-app/.env and fill in. NEVER commit the real .env (it is gitignored).

# DashScope key. Used as `x-api-key` for the Anthropic-shape chat endpoint AND as
# `Authorization: Bearer` for the native text-embedding-v4 endpoint (same key).
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Chat: DeepSeek/Qwen ship on DashScope's Anthropic-shape surface only.
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic

# Embeddings: this key is entitled to text-embedding-v4 on the NATIVE endpoint
# (the OpenAI-compatible /compatible-mode/v1/embeddings is rejected for this key).
DASHSCOPE_EMBEDDINGS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
INTERVIEWER_MODEL=deepseek-v4-flash
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=512

# Fixed live ASR: Doubao / Volcengine Seed ASR 2.0 (server-owned; never exposed
# in Settings). Use the 2.0 duration entitlement unless deployment requires the
# concurrent entitlement. Legacy Seed ASR 1.0 resources are rejected.
VOLC_APP_ID=your-app-id
VOLC_ACCESS_TOKEN=your-access-token
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration
# VOLC_MODEL=bigmodel

# Server
PORT=8787
