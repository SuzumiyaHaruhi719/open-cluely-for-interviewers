# Fixed speech recognition: Doubao Seed ASR 2.0 Duration. These values stay in
# the deployment environment and are never exposed in the Settings renderer.
VOLC_APP_ID=your-app-id
VOLC_ACCESS_TOKEN=your-access-token
VOLC_RESOURCE_ID=volc.seedasr.sauc.duration

# Optional capture behavior
# true = hide this app from screen sharing/screen capture
# false = allow this app to appear in screen sharing/screen capture
HIDE_FROM_SCREEN_CAPTURE=true

# Optional startup mode
# true = start in background mode (window hidden at launch)
# false = show window on startup
START_HIDDEN=false

# Optional screenshot settings
MAX_SCREENSHOTS=50
SCREENSHOT_DELAY=1000

# Optional runtime settings
NODE_ENV=production
NODE_OPTIONS=--max-old-space-size=4096
